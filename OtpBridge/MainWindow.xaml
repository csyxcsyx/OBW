<Window x:Class="OtpBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OtpBridge"
        Width="1120"
        Height="820"
        MinWidth="920"
        MinHeight="680"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        Background="{DynamicResource WindowBackgroundBrush}">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="28,20" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#F6FFF8" Offset="0" />
                    <GradientStop Color="#E7F8EC" Offset="0.58" />
                    <GradientStop Color="#F8FFFB" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="58"
                        Height="58"
                        CornerRadius="16"
                        Background="#FFFFFF"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        Margin="0,0,16,0">
                    <Image Source="Assets/AppIcon.ico"
                           Width="42"
                           Height="42"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="OtpBridge" FontSize="28" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="  ·  托盘常驻，收到验证码后自动复制" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="打开设置" Click="OpenSettings_Click" />
                    <Button Content="复制地址" Click="CopyAddress_Click" Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="复制最近验证码" Click="CopyRecent_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="0.9*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,22,0">
                            <TextBlock Text="连接信息" FontSize="21" FontWeight="SemiBold" />
                            <TextBlock Text="iPhone 快捷指令会把短信内容发送到这里。请优先复制 10.x、172.x、192.168.x 这类局域网地址。"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,16" />
                            <TextBlock Text="监听地址" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBox x:Name="AddressesBox"
                                     Text="{Binding ListeningAddresses, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="15"
                                     MinHeight="84" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="{DynamicResource SurfaceMintBrush}"
                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="API Token" FontSize="17" FontWeight="SemiBold" />
                                <TextBlock Text="这是 iPhone 请求的通行口令。不要发给不信任的人，重新生成后需要同步更新快捷指令。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,12" />
                                <TextBox Text="{Binding ApiToken, Mode=OneWay}"
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         Margin="0,0,0,14" />
                                <Button Content="复制 Token" Click="CopyToken_Click" HorizontalAlignment="Left" Margin="0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24"
                        Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="iPhone 快捷指令配置教程" FontSize="21" FontWeight="SemiBold" />
                        <TextBlock Text="下面按 iPhone 上的实际填写顺序来写。看不懂某一步时，先找界面里的同名文字：收到信息、获取 URL 内容、方法、头部、请求体。"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,18" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="1" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock Text="创建短信自动化" FontWeight="SemiBold" />
                                <TextBlock Text="打开「快捷指令」App，进入「自动化」，新建「收到信息」。条件建议选择：我收到包含「验证码」的信息。完成后顶部应显示「作为输入接收信息」。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>

                            <Border Grid.Row="1" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="2" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock Text="添加「获取 URL 内容」动作" FontWeight="SemiBold" />
                                <TextBlock Text="在动作搜索框输入「获取 URL 内容」。URL 填主窗口上方的监听地址，方法选择 POST。不要填 0.0.0.0，要填电脑的局域网 IP。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>

                            <Border Grid.Row="2" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="3" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock Text="展开「头部」，添加两行 Header" FontWeight="SemiBold" />
                                <TextBlock Text="第一行：Authorization = Bearer + 一个空格 + 主窗口里的 Token。第二行：Content-Type = application/json。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>

                            <Border Grid.Row="3" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="4" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock Text="请求体选择 JSON，只添加一个必填字段" FontWeight="SemiBold" />
                                <TextBlock Text="点「添加新字段」，键填 message，值选择蓝色变量「输入快捷指令的信息」或「收到的信息正文」。这个值必须是短信全文。sender 和 receivedAt 可以不填。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>

                            <Border Grid.Row="4" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="5" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock Text="保存前先测网络" FontWeight="SemiBold" />
                                <TextBlock Text="在 iPhone Safari 打开 http://你的电脑IP:18080/health，看到 {&quot;ok&quot;:true} 就说明手机能访问电脑。若打不开，通常是 IP 填错、不同 Wi-Fi、或 Windows 防火墙未放行。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>

                            <Border Grid.Row="5" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="6" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Row="5" Grid.Column="1">
                                <TextBlock Text="测试一条验证码短信" FontWeight="SemiBold" />
                                <TextBlock Text="给自己发一条类似「您的验证码是 123456，5 分钟内有效」的短信。成功后 Windows 会在右下角提示、剪贴板变成验证码、最近记录新增一行。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24"
                        Margin="0,20,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="最近记录" FontSize="21" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RecentSummary}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="清空记录" Click="ClearRecords_Click" VerticalAlignment="Center" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                        </Grid>

                        <DataGrid Grid.Row="1"
                                  x:Name="RecentGrid"
                                  ItemsSource="{Binding RecentRecords}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  BorderThickness="1"
                                  Margin="0,18,0,0"
                                  MinHeight="240">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding ReceivedAtText}" Width="170" />
                                <DataGridTextColumn Header="发送方" Binding="{Binding Sender}" Width="150" />
                                <DataGridTextColumn Header="验证码" Binding="{Binding Code}" Width="140" />
                                <DataGridTextColumn Header="复制状态" Binding="{Binding CopiedText}" Width="120" />
                                <DataGridTextColumn Header="通知" Binding="{Binding ToastText}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
