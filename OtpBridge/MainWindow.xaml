<Window x:Class="OtpBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OtpBridge"
        Width="1120"
        Height="820"
        MinWidth="920"
        MinHeight="680"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        Background="{DynamicResource WindowBackgroundBrush}">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="28,20" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#F6FFF8" Offset="0" />
                    <GradientStop Color="#E7F8EC" Offset="0.58" />
                    <GradientStop Color="#F8FFFB" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="58"
                        Height="58"
                        CornerRadius="16"
                        Background="#FFFFFF"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        Margin="0,0,16,0">
                    <Image Source="Assets/AppIcon.ico"
                           Width="42"
                           Height="42"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="OtpBridge" FontSize="28" FontWeight="SemiBold" />
                        <Border Background="{DynamicResource SurfaceMintBrush}"
                                BorderBrush="{DynamicResource BorderBrushStrong}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8,3"
                                Margin="12,6,0,4"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="VersionText"
                                       Text="v1.2"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentHoverBrush}" />
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock x:Name="StatusSuffixText" Text="  ·  托盘常驻，收到验证码后自动复制" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="OpenSettingsButton" Content="打开设置" Click="OpenSettings_Click" />
                    <Button x:Name="CopyAddressButton" Content="复制地址" Click="CopyAddress_Click" Style="{StaticResource SecondaryButtonStyle}" />
                    <Button x:Name="CopyRecentButton" Content="复制最近验证码" Click="CopyRecent_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="0.9*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,22,0">
                            <TextBlock x:Name="ConnectionTitleText" Text="连接信息" FontSize="21" FontWeight="SemiBold" />
                            <Border Background="#FFF7D6"
                                    BorderBrush="#E5B94C"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,9"
                                    Margin="0,10,0,12">
                                <TextBlock x:Name="LanReminderText"
                                           Text="重要提醒：iPhone 和 Windows 电脑必须在同一个局域网内，否则快捷指令无法访问本程序。"
                                           Foreground="#6B4E00"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </Border>
                            <TextBlock x:Name="ConnectionDescriptionText" Text="iPhone 快捷指令会把短信内容发送到这里。请优先复制 10.x、172.x、192.168.x 这类局域网地址；如果默认端口被占用，程序会自动换成可用端口，请以这里显示的地址为准。"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,16" />
                            <TextBlock x:Name="AddressLabelText" Text="监听地址" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBox x:Name="AddressesBox"
                                     Text="{Binding ListeningAddresses, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="15"
                                     MinHeight="84" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="{DynamicResource SurfaceMintBrush}"
                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18">
                            <StackPanel>
                                <TextBlock x:Name="TokenTitleText" Text="API Token" FontSize="17" FontWeight="SemiBold" />
                                <TextBlock x:Name="TokenDescriptionText" Text="这是 iPhone 请求的通行口令。不要发给不信任的人，重新生成后需要同步更新快捷指令。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,12" />
                                <TextBox Text="{Binding ApiToken, Mode=OneWay}"
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         Margin="0,0,0,14" />
                                <Button x:Name="CopyTokenButton" Content="复制 Token" Click="CopyToken_Click" HorizontalAlignment="Left" Margin="0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24"
                        Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock x:Name="GuideTitleText" Text="iPhone 快捷指令配置教程" FontSize="21" FontWeight="SemiBold" />
                        <TextBlock x:Name="GuideDescriptionText" Text="下面是给第一次使用快捷指令的用户看的详细步骤。不同 iOS 版本的文字可能略有差异，但要填的内容相同。"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,18" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="1" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock x:Name="Step1TitleText" Text="创建短信自动化" FontWeight="SemiBold" />
                                <TextBlock x:Name="Step1BodyText" Text="打开 iPhone「快捷指令」App，点底部「自动化」，新建自动化并选择「收到信息」。条件建议设置为：我收到包含「验证码」的信息；然后选择「立即运行」。点击「下一步」后，选择「创建新快捷指令」。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>

                            <Border Grid.Row="1" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="2" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock x:Name="Step2TitleText" Text="添加「获取 URL 内容」" FontWeight="SemiBold" />
                                <TextBlock x:Name="Step2BodyText" Text="在动作搜索框搜索并添加「获取 URL 内容」。URL 填 http://XXXXXXX:18080/api/sms，也就是直接复制主窗口里的监听地址；方法选择 POST。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>

                            <Border Grid.Row="2" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="3" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock x:Name="Step3TitleText" Text="填写头部 Header" FontWeight="SemiBold" />
                                <TextBlock x:Name="Step3BodyText" Text="展开「头部」，添加两行：（键） Authorization，（文本） Bearer &lt;主窗口里的 API Token&gt;；（键） Content-Type，（文本） application/json。注意：Bearer 后面必须有一个空格，例如：Bearer abcdefg123456。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>

                            <Border Grid.Row="3" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="4" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock x:Name="Step4TitleText" Text="填写请求体 JSON" FontWeight="SemiBold" />
                                <TextBlock x:Name="Step4BodyText" Text="在「请求体」里选择 JSON。添加一个必填字段：（键） message，文本选择“输入快捷指令的信息”（点击「文本框」后，在输入框上方左右滑动找到“输入快捷指令的信息”并点击）。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>

                            <Border Grid.Row="4" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                                <TextBlock Text="5" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Row="4" Grid.Column="1">
                                <TextBlock x:Name="Step5TitleText" Text="先用固定文本测试" FontWeight="SemiBold" />
                                <TextBlock x:Name="Step5BodyText" Text="如果不确定短信变量是否选对，可以先把 message 的值临时改成固定文本：【测试】您的验证码是 123456，5分钟内有效。手动运行快捷指令后，Windows 应该会弹出提示、剪贴板变成 123456、最近记录新增一行。测试成功后，再把 message 的值改回“输入快捷指令的信息”。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24"
                        Margin="0,20,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="RecentTitleText" Text="最近记录" FontSize="21" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RecentSummary}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <Button x:Name="ClearRecordsButton" Grid.Column="1" Content="清空记录" Click="ClearRecords_Click" VerticalAlignment="Center" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                        </Grid>

                        <DataGrid Grid.Row="1"
                                  x:Name="RecentGrid"
                                  ItemsSource="{Binding RecentRecords}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  BorderThickness="1"
                                  Margin="0,18,0,0"
                                  MinHeight="240">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="TimeColumn" Header="时间" Binding="{Binding ReceivedAtText}" Width="170" />
                                <DataGridTextColumn x:Name="SenderColumn" Header="发送方" Binding="{Binding Sender}" Width="150" />
                                <DataGridTextColumn x:Name="CodeColumn" Header="验证码" Binding="{Binding Code}" Width="140" />
                                <DataGridTextColumn x:Name="CopiedColumn" Header="复制状态" Binding="{Binding CopiedText}" Width="120" />
                                <DataGridTextColumn x:Name="ToastColumn" Header="通知" Binding="{Binding ToastText}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
